---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import AnimatedBackground from '../components/Background';
import About from '../components/pages/About';

const title = 'About - Prabhash Swarnajith';
const description = 'Learn more about Prabhash Swarnajith, a Full-Stack Developer specializing in Spring Boot, React, and cloud-native applications.';
---

<BaseLayout title={title} description={description}>
  <Navbar client:only="react" />
  <AnimatedBackground client:only="react" />
  <About client:only="react" />
</BaseLayout>
